// The Money Command v2 — Prisma Schema
// Fuente de verdad para el modelo de datos. Cualquier cambio acá afecta toda la app.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// User — sincronizado con Supabase Auth. El id viene del auth.users.id de Supabase.
// ============================================================================
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile        Profile?
  monthlyRecords MonthlyRecord[]
  incomes        Income[]
  expenses       Expense[]
  debts          Debt[]
  investments    Investment[]
  goals          Goal[]
  achievements   Achievement[]

  @@map("users")
}

// ============================================================================
// Profile — settings del usuario, brújula, supuestos, configuración de UI
// ============================================================================
model Profile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Datos personales
  name             String?
  ageCurrent       Int?
  ageFreedomTarget Int?
  country          String? // ISO code (US, CO, MX, etc.) — usado para inflación default

  // Brújula (proyectada al header de la app)
  compassWhat         String? @db.VarChar(80)
  compassYear         Int?
  compassContribution String? @db.VarChar(80)

  // Termostato meta a 2 años (manual)
  thermostatTarget Decimal? @db.Decimal(12, 2)

  // Supuestos
  inflationRate     Decimal @default(3.0) @db.Decimal(5, 2) // % anual
  freedomMonthlySpend Decimal? @db.Decimal(12, 2) // si null, usa gastos actuales
  salaryGrowthRate  Decimal @default(2.5) @db.Decimal(5, 2) // % anual

  // Periodo activo persistente (selector global del header).
  // null = la app usa el mes actual.
  activeYear  Int?
  activeMonth Int? // 1-12

  // Método preferido del usuario
  preferredMethod String @default("50/30/20") // 50/30/20 | 50/25/25 | 50/20/30 | 40/20/40

  // Override de Plan B (ingreso pasivo)
  // ------------------------------------------------------------------
  // Por contrato del Sprint 2, Plan B se computa automáticamente desde
  // Investments como monthlyPlanB(positions). El usuario puede activar
  // un override manual; si está activo, el override gana sobre el
  // cálculo. Esto NO duplica datos: el campo computed sigue siendo la
  // fuente para "Plan B automático"; el override es solo un escape
  // explícito por usuario.
  planBManualOverride Boolean  @default(false)
  planBManualAmount   Decimal? @db.Decimal(12, 2)

  // Configuración de UI
  currency String @default("USD") // ISO code, solo cosmético (símbolo y decimales)
  locale   String @default("es")  // es | en

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ============================================================================
// MonthlyRecord — TABLA MAESTRA. Una fila por usuario/año/mes.
// Todos los datos consolidados del usuario en ese mes.
// Los módulos de carga (Income, Expense, Debt, Investment) alimentan estos
// totales vía Server Actions.
// ============================================================================
model MonthlyRecord {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // La fecha la pone el usuario al registrar (puede ser pasada)
  year  Int
  month Int // 1-12
  recordedAt DateTime @default(now())

  // Ingresos
  incomeActive    Decimal @default(0) @db.Decimal(12, 2)
  incomePassive   Decimal @default(0) @db.Decimal(12, 2) // calculado desde Investments
  incomeSecondary Decimal @default(0) @db.Decimal(12, 2)
  incomeTotal     Decimal @default(0) @db.Decimal(12, 2)

  // Gastos por categoría del método
  expenseNeeds       Decimal @default(0) @db.Decimal(12, 2)
  expenseWants       Decimal @default(0) @db.Decimal(12, 2)
  expenseInvestments Decimal @default(0) @db.Decimal(12, 2)
  expenseTotal       Decimal @default(0) @db.Decimal(12, 2)

  // Pasivos (deuda)
  liabilityCard     Decimal @default(0) @db.Decimal(12, 2)
  liabilityPersonal Decimal @default(0) @db.Decimal(12, 2)
  liabilityMortgage Decimal @default(0) @db.Decimal(12, 2)
  liabilityOther    Decimal @default(0) @db.Decimal(12, 2)
  liabilityTotal    Decimal @default(0) @db.Decimal(12, 2)

  // Activos
  assetCash        Decimal @default(0) @db.Decimal(12, 2)
  assetInvestments Decimal @default(0) @db.Decimal(12, 2)
  assetRealEstate  Decimal @default(0) @db.Decimal(12, 2)
  assetOther       Decimal @default(0) @db.Decimal(12, 2)
  assetTotal       Decimal @default(0) @db.Decimal(12, 2)

  // Calculados (snapshot del momento del registro)
  netWorth        Decimal @default(0) @db.Decimal(12, 2)
  savingsRate     Decimal @default(0) @db.Decimal(5, 2) // %
  weightedReturn  Decimal @default(8.0) @db.Decimal(5, 2) // %

  // No realizado (lo que se pudo ahorrar y no se hizo)
  potentialSavingsMissed Decimal @default(0) @db.Decimal(12, 2)

  // ============================================================
  // Campos doctrinales — ARQUITECTURA.md §4 (canónicos)
  //
  // Estos son los campos canónicos según la ley del repo. Los
  // campos legacy (expenseNeeds/Wants/Investments, liabilityTotal,
  // assetInvestments, potentialSavingsMissed) coexisten por ahora
  // y se unifican en FASE B (eliminación de Monthly Entry vieja).
  // ============================================================

  // Canastas del gasto (Esenciales / Estilo / Libertad)
  essentials Decimal @default(0) @db.Decimal(12, 2)
  style      Decimal @default(0) @db.Decimal(12, 2)
  freedom    Decimal @default(0) @db.Decimal(12, 2)

  // Snapshots del estado actual al cierre del mes
  debtTotal         Decimal @default(0) @db.Decimal(12, 2)
  portfolioValue    Decimal @default(0) @db.Decimal(12, 2)
  investedThisMonth Decimal @default(0) @db.Decimal(12, 2)
  notRealized       Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@map("monthly_records")
}

// ============================================================================
// Income — fuentes de ingreso individuales (Plan A, Plan C)
// Plan B se calcula desde Investments, no se almacena acá
// ============================================================================
model Income {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  plan      String // "A" | "C" (B se calcula desde Investments)
  amount    Decimal @db.Decimal(12, 2) // monto mensual
  isActive  Boolean @default(true)

  // Período al que pertenece (ARQUITECTURA §3: Income es flujo del mes).
  // Cada fila vive en un mes/año concreto; el selector global decide en qué
  // período se carga y se consulta.
  year  Int
  month Int // 1-12

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, year, month])
  @@map("incomes")
}

// ============================================================================
// Expense — gastos individuales con categorización
// Las suscripciones y microgastos también van acá (con periodicity adecuada)
// ============================================================================
model Expense {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  category    String // vivienda | comida | transporte | salud | entretenimiento | educacion | otros
  type        String // "fixed" | "variable"
  classification String // LEGACY (need|want|investment): se deriva de basket. Ver CONTEXT.md
  periodicity String // "once" | "monthly" | "annual"
  amount      Decimal @db.Decimal(12, 2) // REAL pagado

  // Canasta doctrinal (ARQUITECTURA §9 / ANEXO §2). Fuente de verdad del módulo.
  basket String // "essentials" | "style" | "freedom"

  // Presupuesto del gasto (KPI Total Presupuesto vs Total Real)
  budget Decimal @default(0) @db.Decimal(12, 2)

  // Período al que pertenece (ARQUITECTURA §3: Expenses es flujo del mes),
  // mismo patrón que Income (commit 621f2b4).
  year  Int
  month Int // 1-12

  // Fecha real de la compra (lector de extractos de tarjeta). Opcional: los
  // gastos manuales y los existentes quedan null. Permite dedup preciso
  // (comercio + monto + fecha) al importar un resumen.
  purchaseDate DateTime?

  // Suscripción recurrente (flag dedicado, NO se infiere de isAntExpense+style:
  // un gasto hormiga fijo en Estilo —ej. café diario— no es suscripción).
  // Alimenta el resumen mensual/anual y la futura GASTOS_HORMIGA_MES del Coach.
  isSubscription Boolean @default(false)

  // Para gastos hormiga (microgastos)
  isAntExpense    Boolean  @default(false)
  unitAmount      Decimal? @db.Decimal(12, 2) // ej. $5 por café
  frequencyPerMonth Int?    // ej. 20 días al mes

  // Vínculo opcional a una Meta (rediseño Metas integrado, Etapa 1).
  // Un gasto real puede etiquetarse como aporte a una meta: además de contar en
  // su canasta como siempre, suma al progreso de esa meta (progreso = suma de
  // gastos vinculados). Es solo presentación: NO altera la consolidación.
  //
  // onDelete: SetNull es CRÍTICO. Un Expense es un gasto real que entra al
  // MonthlyRecord; al borrar una meta el gasto NO se debe borrar (corromperia
  // los totales). Solo se desvincula (goalId -> NULL).
  goalId String? @db.Uuid
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, isAntExpense])
  @@index([userId, year, month])
  @@index([userId, goalId])
  // Blindaje contra duplicados de la generación automática de Metas (Etapa 3b):
  // a lo sumo UN gasto por meta y período. Para gastos sin meta (goalId NULL),
  // Postgres trata los NULL como distintos, así que NO restringe los gastos
  // normales: solo impide dos gastos de la MISMA meta en el mismo year/month.
  @@unique([goalId, year, month])
  @@map("expenses")
}

// ============================================================================
// Debt — cada deuda con sus parámetros
// ============================================================================
model Debt {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name           String
  type           String // "card" | "auto_loan" | "student_loan" | "personal_loan" | "mortgage" | "other"
  balance        Decimal @db.Decimal(12, 2)
  apr            Decimal @db.Decimal(5, 2) // % anual
  minPayment     Decimal @db.Decimal(12, 2)
  currentPayment Decimal @db.Decimal(12, 2) // pago mensual real (mueve el saldo)
  termMonths     Int?    // cuotas restantes (opcional, lo ingresa la persona)
  originalAmount Decimal? @db.Decimal(12, 2) // para calcular % reducido

  // Etiqueta educativa (doctrina §2): no cambia la canasta del pago, solo
  // genera consciencia consumo vs inversión.
  purpose String // "consumption" | "investment"

  // Fecha de corte del snapshot: a qué período corresponde el `balance` de
  // hoy. NO es period-scoping (sigue habiendo una sola fila por deuda); es
  // el "as-of" del saldo vivo, para amortizar mes a mes desde el punto
  // correcto sin sobre-descontar una deuda recién agregada.
  balanceAsOfYear  Int
  balanceAsOfMonth Int // 1-12

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("debts")
}

// ============================================================================
// Investment — cada posición del portafolio
//
// Cinco categorías doctrinales (Sprint 2):
//   "fixed_income" — Renta fija (bonos, fondos de bonos, plazo fijo)
//   "equity"       — Renta variable (acciones, ETFs, fondos)
//   "real_estate"  — Bienes raíces (propiedades, REITs)
//   "speculative"  — Cripto / Especulativo
//   "other"        — Otros
//
// passiveYield = % anual que la posición entrega como FLUJO (dividendos,
// intereses, renta neta). NO es la apreciación del capital. Plan B mensual
// se computa en Investments como:
//
//     planB = Σ (capital × passiveYield) / 12
//
// y es la ÚNICA fuente de verdad para el ingreso pasivo del usuario.
//
// expectedReturn (capa A de proyección) = retorno TOTAL anual esperado del
// activo (apreciación + yield reinvertido). Distinto de passiveYield: el
// crecimiento de la proyección usa expectedReturn; el Plan B sigue usando
// SOLO passiveYield. Nunca se mezclan (ARQUITECTURA §8, las tres tasas).
//
// Lo que NO está acá:
//   - Divisor del NLF (4%): vive en formulas.ts como NLF_DIVISOR. No es
//     un rendimiento ni una tasa de retiro.
// ============================================================================
model Investment {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category     String  // "fixed_income" | "equity" | "real_estate" | "speculative" | "other"
  label        String?
  capital      Decimal @db.Decimal(12, 2)
  passiveYield Decimal @db.Decimal(6, 4) // flujo pasivo anual, fracción (0.04 = 4%). Alimenta Plan B.

  // Proyección de interés compuesto (capa A). NO tocan el Plan B.
  monthlyContribution Decimal @default(0) @db.Decimal(12, 2) // aporte mensual
  expectedReturn      Decimal @db.Decimal(6, 4) // retorno total anual, fracción (0.08 = 8%)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@map("investments")
}

// ============================================================================
// Goal — metas categorizadas por canasta (Esenciales | Estilo | Libertad)
//
// Es estado actual (snapshot), NO flujo del mes: no lleva year/month, sigue
// la convención de Investment/Debt. NO entra a la consolidación mensual.
// ============================================================================
model Goal {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  // Canasta doctrinal, igual que en Expense. Fuente de verdad del módulo.
  basket      String // "essentials" | "style" | "freedom"
  // LEGACY (need|want|patrimony): se deriva de basket. Ver CONTEXT.md.
  category    String
  // Tipo de meta (rediseño Metas, Etapa 2.5):
  //   "automatic" — ahorro programado: genera un gasto real en su canasta cada
  //                 mes por el monto de monthlyContribution (anclado en createdAt,
  //                 generacion idempotente). Implementacion de la generacion: Etapa 3b.
  //   "tagged"    — compra etiquetada: la persona vincula gastos reales (goalId)
  //                 cuando ocurren. Es el comportamiento de la Etapa 1.
  // Default "tagged": las metas existentes y nuevas son etiquetadas salvo opt-in.
  goalType    String @default("tagged")
  targetAmount Decimal @db.Decimal(12, 2)
  targetDate  DateTime? // opcional: para medir si va a tiempo o atrasado
  // DEPRECADO (rediseño Metas integrado): el progreso ya NO se lee de acá.
  // Ahora el progreso = suma de gastos vinculados (Expense.goalId). Se conserva
  // la columna para no perder datos historicos; no se escribe ni se lee mas.
  currentAmount Decimal @default(0) @db.Decimal(12, 2)
  // Cuota "pegajosa": el aporte/cuota mensual que define la persona (su plan).
  // Se mantiene hasta que la modifique; base de la proyeccion por plan.
  monthlyContribution Decimal @default(0) @db.Decimal(12, 2)

  // Gastos reales vinculados a esta meta (back-relation de Expense.goalId).
  // El progreso de la meta se calcula sumando estos gastos. Presentacion pura.
  expenses Expense[]

  isActive   Boolean  @default(true)
  isAchieved Boolean  @default(false)
  achievedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, targetDate])
  @@map("goals")
}

// ============================================================================
// Achievement — logros desbloqueados (no se repiten)
// Ver lib/achievements.ts para la lista oficial [01]-[14]
// ============================================================================
model Achievement {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String // "[01]" | "[02]" | ... | "[14]"
  name      String
  message   String
  unlockedAt DateTime @default(now())

  @@unique([userId, code])
  @@index([userId])
  @@map("achievements")
}

// ============================================================================
// SavedScenario — escenarios guardados desde el Simulador (Freedom Calc Tab 5)
// ============================================================================
model SavedScenario {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  name                 String
  monthlyContribution  Decimal @db.Decimal(12, 2)
  weightedReturn       Decimal @db.Decimal(5, 2)
  wantsReductionPct    Decimal @default(0) @db.Decimal(5, 2)
  incomeIncreasePct    Decimal @default(0) @db.Decimal(5, 2)
  extraCapital         Decimal @default(0) @db.Decimal(12, 2)

  // Resultados snapshot al momento de guardar
  yearsToFreedom       Decimal @db.Decimal(5, 2)
  projectedNetWorth    Decimal @db.Decimal(12, 2)
  passiveIncomeMonthly Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("saved_scenarios")
}
