# The Money Command v2 — variables de entorno
# Copiar a .env.local y completar con valores reales del proyecto Supabase.

# ============================================================================
# Supabase
# ============================================================================
# Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"

# Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Settings > API > service_role (SECRETA — server only, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================================
# Prisma / Postgres
# ============================================================================
# Settings > Database > Connection string (modo "Transaction" para serverless)
# Reemplazar [YOUR-PASSWORD] y [YOUR-PROJECT-REF].
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Connection string directa (modo "Session") para migraciones de Prisma.
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ============================================================================
# App
# ============================================================================
# Base URL del sitio — usada en el callback de auth y emails de recovery.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
